# ===============================================================
# 冒央会社 / Maoyang Taiwan Inc - Environment Variables
# ===============================================================

# ─── Telegram bot order push (REQUIRED for order submission) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── USDT TRC20 automatic receipt confirmation (optional) ───
# TronGrid works without a key at low volume; a key is recommended in production.
TRONGRID_API_KEY=
# Required when /api/admin/usdt-check is invoked by Vercel Cron or another scheduler.
# Vercel sends this as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ─── Order storage (Vercel KV / Upstash Redis - REQUIRED for order query) ───
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Resend email delivery (REQUIRED for site email sending) ───
# Create an API key in Resend after verifying liumeiti.vip.
RESEND_API_KEY=
# Resend dashboard Webhook endpoint: https://www.liumeiti.vip/api/webhooks/resend
# Subscribe to sent/delivered/delayed/bounced/complained/failed/suppressed/opened/clicked.
RESEND_WEBHOOK_SECRET=
EMAIL_PROVIDER=resend
MAIL_FROM=info@liumeiti.vip
MAIL_FROM_NAME=冒央会社
ENABLE_EMAIL_TEST=false

# Legacy SMTP is disabled unless EMAIL_PROVIDER is explicitly changed to smtp.

# ─── Resend SMTP settings (used when EMAIL_PROVIDER=smtp) ───
# Password is the Resend API key. Do not commit it.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=info@liumeiti.vip

# ─── Brevo emergency SMTP fallback (transactional mail only) ───
# Used only when Resend explicitly reports a daily/monthly quota error.
FALLBACK_SMTP_PROVIDER=brevo
FALLBACK_SMTP_HOST=smtp-relay.brevo.com
FALLBACK_SMTP_PORT=587
FALLBACK_SMTP_USER=
FALLBACK_SMTP_PASS=
FALLBACK_SMTP_FROM=info@liumeiti.vip
# Brevo transactional webhook:
# https://www.liumeiti.vip/api/webhooks/brevo?token=<BREVO_WEBHOOK_TOKEN>
BREVO_WEBHOOK_TOKEN=

# ─── Branding (optional - defaults shown) ───
BRAND_NAME=冒央会社
SITE_DOMAIN=liumeiti.vip
SUPPORT_CONTACT=请通过 QQ 2802632995 / WhatsApp +1 4315093334 / Telegram @MaoyangSupport 联系在线客服

# ─── Admin dashboard (REQUIRED for /admin) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── User auth (REQUIRED for register/login) — random 32+ chars ───
AUTH_SECRET=

# ─── Google OAuth login (optional) ───
# SITE_URL must match the production domain, for example https://liumeiti.vip
SITE_URL=https://liumeiti.vip
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Webhook (optional - alternative to Telegram) ───
# ORDER_WEBHOOK_URL=
