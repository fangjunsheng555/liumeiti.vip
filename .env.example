# ===============================================================
# 冒央会社 / Maoyang Taiwan Inc - Environment Variables
# ===============================================================

# ─── Telegram bot order push (REQUIRED for order submission) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Order storage (Vercel KV / Upstash Redis - REQUIRED for order query) ───
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Resend email delivery (REQUIRED for site email sending) ───
# Create an API key in Resend after verifying liumeiti.vip.
RESEND_API_KEY=
EMAIL_PROVIDER=smtp
MAIL_FROM=info@liumeiti.vip
MAIL_FROM_NAME=冒央会社
ENABLE_EMAIL_TEST=false

# Legacy SMTP is disabled unless EMAIL_PROVIDER=smtp.

# ─── Resend SMTP settings (used when EMAIL_PROVIDER=smtp) ───
# Password is the Resend API key. Do not commit it.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=info@liumeiti.vip

# ─── Branding (optional - defaults shown) ───
BRAND_NAME=冒央会社
SITE_DOMAIN=liumeiti.vip
SUPPORT_CONTACT=请通过 QQ 2802632995 / WhatsApp +1 4315093334 / Telegram @MaoyangSupport 联系在线客服

# ─── Admin dashboard (REQUIRED for /admin) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── User auth (REQUIRED for register/login) — random 32+ chars ───
AUTH_SECRET=

# ─── Google OAuth login (optional) ───
# SITE_URL must match the production domain, for example https://liumeiti.vip
SITE_URL=https://liumeiti.vip
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Webhook (optional - alternative to Telegram) ───
# ORDER_WEBHOOK_URL=
