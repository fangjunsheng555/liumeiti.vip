# ===============================================================
# 冒央会社 / Maoyang Taiwan Inc - Environment Variables
# ===============================================================

# ─── Telegram bot order push (REQUIRED for order submission) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Order storage (Vercel KV / Upstash Redis - REQUIRED for order query) ───
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── iCloud+ Custom Domain SMTP (REQUIRED for order email confirmation) ───
# 1. Set up your custom domain at iCloud → Settings → iCloud+ → Custom Email Domain
# 2. Generate an app-specific password at https://appleid.apple.com
#    → Sign-in & Security → App-Specific Passwords
# 3. SMTP_USER is your Apple ID email (e.g. youraccount@icloud.com)
# 4. SMTP_FROM is the sender address shown to recipients (your custom domain email)
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Branding (optional - defaults shown) ───
BRAND_NAME=冒央会社
SITE_DOMAIN=liumeiti.vip
SUPPORT_CONTACT=请通过 QQ 2802632995 / WhatsApp +1 4315093334 / Telegram @MaoyangSupport 联系在线客服

# ─── Admin dashboard (REQUIRED for /admin) ───
ADMIN_PASSWORD=

# ─── User auth (REQUIRED for register/login) — random 32+ chars ───
AUTH_SECRET=

# ─── Webhook (optional - alternative to Telegram) ───
# ORDER_WEBHOOK_URL=
